{
    "name": "@futarchy-interface/replay-harness-ui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "UI-side scaffold of the Forked Replay Harness (Playwright + wallet stub). See PROGRESS.md.",
    "scripts": {
        "phase-status": "node -e \"console.log('Forked Replay Harness — Phase 4 (synthetic wallet). See auto-qa/harness/PROGRESS.md');\"",
        "wallet:demo": "node fixtures/wallet-stub.mjs",
        "smoke:wallet": "node --test tests/smoke-wallet-stub.test.mjs",
        "smoke:contracts": "node --test tests/smoke-contract-calls.test.mjs",
        "contracts:demo": "node scripts/contracts.mjs",
        "test": "node --test 'tests/**/*.test.mjs'",
        "ui": "HARNESS_NO_WEBSERVER=1 playwright test",
        "ui:ui": "HARNESS_NO_WEBSERVER=1 playwright test --ui",
        "ui:full": "playwright test",
        "ui:full:ui": "playwright test --ui",
        "ui:report": "playwright show-report",
        "replay": "echo 'TODO Phase 5 — full chain↔api↔ui replay' && exit 1"
    },
    "dependencies": {
        "@noble/curves": "^2.2.0",
        "@noble/hashes": "^2.2.0",
        "viem": "^2.48.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1"
    }
}
